{
  "name": "util_10pct_multi_cluster_constrained",
  "description": "At 10% utilization: Mixed fleet (SMT + No-SMT pools) using constrained (resource_constraints, same HW) model. VMs split by vCPU discount trait: below breakeven (0.850) go to no-SMT pool, above go to SMT pool. Uniform discount distribution from 0.5 to 1.0 (avg 0.75). No-SMT pool gets weighted average discount as vcpu_demand_multiplier; SMT pool uses multiplier 1.0. Both pools use resource_constraints for fixed server capacities. Sweep split_point to see sensitivity.",
  "scenarios": {
    // Pure SMT baseline for comparison (same HW with resource constraints)
    "smt_baseline": {
      "processor": "smt",
      "oversub_ratio": 3.0,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 4.8,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 75.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    // Sub-scenario: SMT pool (receives VMs above the split point)
    "smt_pool": {
      "processor": "smt",
      "oversub_ratio": 3.0,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 4.8,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 75.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    // Sub-scenario: No-SMT pool on same SMT hardware with SMT disabled
    // vcpu_demand_multiplier will be overridden by trait weighted_average
    // Same physical server as SMT: 768GB memory, 12TB SSD
    // 80 HW threads → doubled capacity_per_thread vs purpose-built
    "nosmt_pool": {
      "processor": "nosmt_smt_hw_linear",
      "oversub_ratio": 5.0,
      "vcpu_demand_multiplier": 1.0,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 9.6,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 150.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    // Homogeneous no-SMT: all VMs on no-SMT (same HW) at fleet-average discount (0.75)
    "nosmt_homogeneous": {
      "processor": "nosmt_smt_hw_linear",
      "oversub_ratio": 5.0,
      "vcpu_demand_multiplier": 0.75,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 9.6,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 150.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    // Composite: split fleet by vCPU discount trait
    "mixed_fleet": {
      "composite": {
        "nosmt_pool": {
          "allocation": "below_split",
          "parameter_effects": {"vcpu_demand_multiplier": "weighted_average"}
        },
        "smt_pool": {
          "allocation": "above_split",
          "parameter_effects": {"vcpu_demand_multiplier": 1.0}
        }
      },
      "split_trait": "vcpu_discount",
      // Breakeven from constrained 10% util analysis: 0.850
      "split_point": 0.850
    }
  },
  "workload": {
    "total_vcpus": 10000,
    "avg_util": 0.1,
    "traits": {
      // Uniform distribution from 0.5 to 1.0 in 0.05 steps
      // 11 equal bins, each with fraction 1/11 ≈ 0.0909
      "vcpu_discount": {
        "type": "discrete",
        "bins": [
          {"value": 0.50, "vcpu_fraction": 0.0909},
          {"value": 0.55, "vcpu_fraction": 0.0909},
          {"value": 0.60, "vcpu_fraction": 0.0909},
          {"value": 0.65, "vcpu_fraction": 0.0909},
          {"value": 0.70, "vcpu_fraction": 0.0909},
          {"value": 0.75, "vcpu_fraction": 0.0909},
          {"value": 0.80, "vcpu_fraction": 0.0909},
          {"value": 0.85, "vcpu_fraction": 0.0909},
          {"value": 0.90, "vcpu_fraction": 0.0909},
          {"value": 0.95, "vcpu_fraction": 0.0909},
          {"value": 1.00, "vcpu_fraction": 0.0909}
        ]
      }
    }
  },
  "analysis": {
    "type": "compare_sweep",
    "baseline": "smt_baseline",
    "sweep_scenarios": ["nosmt_homogeneous", "mixed_fleet"],
    "sweep_parameter": "split_point",
    "sweep_parameter_label": "vCPU Discount Split Point",
    "sweep_values": [0.50, 0.55, 0.60, 0.65, 0.70, 0.75, 0.80, 0.85, 0.90, 0.95, 1.01],
    "show_breakeven_marker": true,
    "separate_metric_plots": true,
    "show_plot_title": false,
    "x_axis_markers": [0.850],
    "x_axis_marker_labels": ["breakeven (0.850)"],
    "labels": {
      "smt_baseline": "SMT (R=3.0, same HW)",
      "nosmt_homogeneous": "No-SMT Homogeneous (R=5.0, discount=0.75)",
      "mixed_fleet": "Mixed Fleet (SMT + No-SMT, same HW)"
    }
  },
  "processor": {
    "smt": "configs/shared/genoa_processors.jsonc:genoa_smt",
    "nosmt_smt_hw_linear": "configs/shared/genoa_processors.jsonc:genoa_nosmt_smt_hw_linear"
  },
  "cost": {
    "carbon_intensity_g_kwh": 175,
    "electricity_cost_usd_kwh": 0.28,
    "lifetime_years": 6
  },
  "power_curve": {
    "type": "polynomial"
  },
  "output_dir": "./results/oversub_analysis/genoa/linear/multi_cluster/util_10pct_multi_cluster_constrained"
}
