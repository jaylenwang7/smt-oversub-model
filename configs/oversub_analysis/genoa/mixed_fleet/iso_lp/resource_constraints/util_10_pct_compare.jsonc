{
  "name": "iso_lp_resource_constraints_util_10pct_compare",
  "description": "At 10% utilization: Comparison of homogeneous SMT (R=2.59), homogeneous no-SMT (R=5.58, discount=0.75), and mixed fleet with metric-specific auto-breakeven splits. Iso-LP basis, Same HW resource model.",
  "scenarios": {
    "smt_homogeneous": {
      "processor": "smt",
      "oversub_ratio": 2.59,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 4.8,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 75.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    "nosmt_homogeneous": {
      "processor": "nosmt_smt_hw_linear",
      "oversub_ratio": 5.58,
      "vcpu_demand_multiplier": 0.75,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 9.6,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 150.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    "smt_pool": {
      "processor": "smt",
      "oversub_ratio": 2.59,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 4.8,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 75.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    "nosmt_pool": {
      "processor": "nosmt_smt_hw_linear",
      "oversub_ratio": 5.58,
      "vcpu_demand_multiplier": 1.0,
      "resource_constraints": {
        "memory_gb": {
          "capacity_per_thread": 9.6,
          "demand_per_vcpu": 4.0
        },
        "ssd_gb": {
          "capacity_per_thread": 150.0,
          "demand_per_vcpu": 50.0
        }
      }
    },
    "mixed_fleet_carbon": {
      "composite": {
        "nosmt_pool": {
          "allocation": "below_split",
          "parameter_effects": {
            "vcpu_demand_multiplier": "weighted_average"
          }
        },
        "smt_pool": {
          "allocation": "above_split",
          "parameter_effects": {
            "vcpu_demand_multiplier": 1.0
          }
        }
      },
      "split_trait": "vcpu_discount",
      "split_point": {
        "auto_breakeven": {
          "baseline_scenario": "smt_pool",
          "target_scenario": "nosmt_pool",
          "target_parameter": "vcpu_demand_multiplier",
          "match_metric": "carbon",
          "search_bounds": [
            0.5,
            1.0
          ]
        }
      }
    },
    "mixed_fleet_tco": {
      "composite": {
        "nosmt_pool": {
          "allocation": "below_split",
          "parameter_effects": {
            "vcpu_demand_multiplier": "weighted_average"
          }
        },
        "smt_pool": {
          "allocation": "above_split",
          "parameter_effects": {
            "vcpu_demand_multiplier": 1.0
          }
        }
      },
      "split_trait": "vcpu_discount",
      "split_point": {
        "auto_breakeven": {
          "baseline_scenario": "smt_pool",
          "target_scenario": "nosmt_pool",
          "target_parameter": "vcpu_demand_multiplier",
          "match_metric": "tco",
          "search_bounds": [
            0.5,
            1.0
          ]
        }
      }
    }
  },
  "workload": {
    "total_vcpus": 100000,
    "avg_util": 0.1,
    "traits": {
      "vcpu_discount": {
        "type": "discrete",
        "bins": [
          {
            "value": 0.5,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.55,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.6,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.65,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.7,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.75,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.8,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.85,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.9,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 0.95,
            "vcpu_fraction": 0.0909
          },
          {
            "value": 1.0,
            "vcpu_fraction": 0.0909
          }
        ]
      }
    }
  },
  "analysis": {
    "type": "compare",
    "baseline": "smt_homogeneous",
    "scenarios": [
      "smt_homogeneous",
      "nosmt_homogeneous",
      "mixed_fleet_carbon",
      "mixed_fleet_tco"
    ],
    "separate_metric_plots": true,
    "show_plot_title": false,
    "labels": {
      "smt_homogeneous": "SMT\n(R=2.59)",
      "nosmt_homogeneous": "No-SMT\n(R=5.58)",
      "mixed_fleet_carbon": "Mixed Fleet\n(CARBON split)",
      "mixed_fleet_tco": "Mixed Fleet\n(TCO split)"
    }
  },
  "processor": {
    "smt": "configs/shared/genoa_processors.jsonc:genoa_smt",
    "nosmt_linear": "configs/shared/genoa_processors.jsonc:genoa_nosmt_linear",
    "nosmt_smt_hw_linear": "configs/shared/genoa_processors.jsonc:genoa_nosmt_smt_hw_linear"
  },
  "cost": {
    "carbon_intensity_g_kwh": 175,
    "electricity_cost_usd_kwh": 0.28,
    "lifetime_years": 6
  },
  "power_curve": {
    "type": "polynomial"
  },
  "output_dir": "./results/oversub_analysis/genoa/mixed_fleet/iso_lp/resource_constraints/util_10pct_compare"
}
